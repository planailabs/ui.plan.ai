---
interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	noindex?: boolean;
	bodyClass?: string;
}

const {
	title = 'ui.plan.ai',
	description = 'Supabase-backed platform for agent-generated UI streams.',
	canonicalPath = Astro.url.pathname,
	noindex = false,
	bodyClass = '',
} = Astro.props;

const site = Astro.site ?? new URL('https://ui.plan.ai');
const canonicalUrl = new URL(canonicalPath, site).toString();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		{noindex && <meta name="robots" content="noindex" />}
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="theme-color" content="#000000" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="ui.plan.ai" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="author" content="plan.ai" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<style is:global>
			:root {
				--bg: #000;
				--fg: #fafafa;
				--muted: #a1a1aa;
				--soft: #71717a;
				--line: #27272a;
				--line-strong: #3f3f46;
				--accent: #a5f3fc;
				--accent-strong: #22d3ee;
				--success: #4ade80;
				--warning: #fbbf24;
				--panel: #111114;
				--panel-soft: rgba(39, 39, 42, 0.42);
				font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
				color: var(--fg);
				background: var(--bg);
			}

			* { box-sizing: border-box; }

			html {
				color-scheme: dark;
				background: var(--bg);
			}

			body {
				margin: 0;
				min-height: 100vh;
				color: var(--fg);
				background: var(--bg);
				font-size: 14px;
				line-height: 1.55;
				-webkit-font-smoothing: antialiased;
			}

			body.not-found {
				display: grid;
				place-items: center;
			}

			a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
				padding-bottom: 1px;
				transition: color 120ms ease, border-color 120ms ease, background-color 120ms ease;
			}

			a:hover,
			a:focus-visible {
				color: var(--success);
				border-color: var(--success);
				outline: none;
			}

			.skip-link {
				position: fixed;
				z-index: 100;
				top: 12px;
				left: 12px;
				transform: translateY(-150%);
				padding: 10px 12px;
				border: 1px solid var(--accent);
				border-radius: 6px;
				color: var(--bg);
				background: var(--accent);
			}

			.skip-link:focus-visible {
				transform: translateY(0);
				color: var(--bg);
				outline: 2px solid var(--success);
				outline-offset: 3px;
			}

			::selection {
				color: #001013;
				background: var(--accent);
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					animation-duration: 0.001ms !important;
					animation-iteration-count: 1 !important;
					scroll-behavior: auto !important;
					transition-duration: 0.001ms !important;
				}
			}
		</style>
	</head>
	<body class={bodyClass}>
		<a class="skip-link" href="#main">Skip to main content</a>
		<slot />
	</body>
</html>
