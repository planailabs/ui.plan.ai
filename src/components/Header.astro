---
interface Props {
	subtitle?: string;
}
const { subtitle } = Astro.props;
---

<header class="site-header">
	<div class="row">
		<a href="/" class="brand" aria-label="ui.plan.ai home">ui.plan.ai</a>
		<nav>
			<a href="/docs/">docs</a>
			<a href="/workbench/">workbench</a>
		</nav>
	</div>
	{subtitle && <p class="subtitle">{subtitle}</p>}
</header>

<style>
	.site-header {
		margin-bottom: 40px;
		padding-bottom: 24px;
		border-bottom: 1px solid var(--line);
	}
	.row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 24px;
		flex-wrap: wrap;
	}
	.brand {
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: 16px;
		font-weight: 500;
		color: var(--fg);
		border-bottom: 0;
	}
	.brand:hover { color: var(--accent); }
	nav { display: flex; gap: 18px; font-size: 12.5px; }
	.subtitle {
		margin: 12px 0 0;
		color: var(--dim);
		font-size: 12.5px;
	}
</style>
