---
import StatusPill from './StatusPill.astro';
import { formatDateKey, type ResolvedStream } from '../data/v1Demo';

interface Props {
	stream: ResolvedStream;
	headingLevel?: 1 | 2;
}

const { stream, headingLevel = 1 } = Astro.props;
const HeadingTag = `h${headingLevel}` as 'h1' | 'h2';
---

<header class="stream-header">
	<div>
		<p class="eyebrow">Public stream</p>
		<HeadingTag>{stream.agent.name} / {stream.channel.name} / {formatDateKey(stream.dateKey)}</HeadingTag>
		<p>{stream.agent.description}</p>
	</div>
	<dl class="stream-meta" aria-label="Resolved route metadata">
		<StatusPill label="promoted only" tone="success" />
		<div><dt>Tenant</dt><dd>{stream.tenant.slug}</dd></div>
		<div><dt>Agent</dt><dd>{stream.agent.slug}</dd></div>
		<div><dt>Channel</dt><dd>{stream.channel.slug}</dd></div>
	</dl>
</header>

<style>
	.stream-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 28px;
		margin-bottom: 28px;
		align-items: end;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: var(--success);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2 {
		margin: 0 0 16px;
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: clamp(34px, 6vw, 64px);
		font-weight: 520;
		letter-spacing: -0.045em;
		line-height: 1;
	}

	p {
		max-width: 640px;
		margin: 0;
		color: var(--muted);
	}

	.stream-meta {
		display: grid;
		justify-items: start;
		gap: 8px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 22px;
		background: var(--panel);
		color: var(--muted);
		font-size: 12px;
	}

	.stream-meta div {
		display: grid;
		gap: 2px;
	}

	dt {
		color: var(--soft);
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	dd {
		margin: 0;
	}

	@media (max-width: 780px) {
		.stream-header {
			grid-template-columns: 1fr;
		}
	}
</style>
