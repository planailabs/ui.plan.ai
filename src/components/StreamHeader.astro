---
import StatusPill from './StatusPill.astro';
import { formatDateKey, type ResolvedStream } from '../data/v1Demo';

interface Props {
	stream: ResolvedStream;
}

const { stream } = Astro.props;
---

<header class="stream-header">
	<div>
		<p class="eyebrow">Public stream</p>
		<h1>{stream.agent.name} / {stream.channel.name} / {formatDateKey(stream.dateKey)}</h1>
		<p>{stream.agent.description}</p>
	</div>
	<div class="stream-meta" aria-label="Resolved route metadata">
		<StatusPill label="promoted only" tone="success" />
		<span>tenant: {stream.tenant.slug}</span>
		<span>agent: {stream.agent.slug}</span>
		<span>channel: {stream.channel.slug}</span>
	</div>
</header>

<style>
	.stream-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 28px;
		margin-bottom: 28px;
		align-items: end;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: var(--success);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 16px;
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: clamp(34px, 6vw, 64px);
		font-weight: 520;
		letter-spacing: -0.045em;
		line-height: 1;
	}

	p {
		max-width: 640px;
		margin: 0;
		color: var(--muted);
	}

	.stream-meta {
		display: grid;
		justify-items: start;
		gap: 8px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 22px;
		background: var(--panel);
		color: var(--muted);
		font-size: 12px;
	}

	@media (max-width: 780px) {
		.stream-header {
			grid-template-columns: 1fr;
		}
	}
</style>
