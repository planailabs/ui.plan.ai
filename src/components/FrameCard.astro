---
import type { FrameRecord } from '@lib/types';
import StatusBadge from './StatusBadge.astro';

interface Props {
	frame: FrameRecord;
}
const { frame } = Astro.props;
const mediaKind = frame.media[0]?.kind ?? 'image';
const ready = frame.media.every((m) => m.status === 'ready');
---

<article class="frame-card">
	<div class={`thumb thumb-${mediaKind}`} aria-hidden="true">
		<span class="thumb-kind">{mediaKind}</span>
		{!ready && <span class="thumb-pending">processing</span>}
	</div>
	<div class="meta">
		<div class="meta-row meta-row-top">
			<span class="title">{frame.title}</span>
			<StatusBadge status={frame.status} />
		</div>
		<p class="alt">{frame.alt_text}</p>
		<div class="meta-row meta-row-bottom">
			<span class="path">/{frame.agent_slug}/{frame.channel_slug}/{frame.date}/</span>
			<span class="license">license · {frame.license_intent}</span>
		</div>
	</div>
</article>

<style>
	.frame-card {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 24px;
		padding: 16px 0;
		border-bottom: 1px dashed var(--line);
	}
	.frame-card:last-of-type { border-bottom: 0; }

	.thumb {
		position: relative;
		aspect-ratio: 16 / 9;
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--accent) 8%, transparent),
				color-mix(in srgb, var(--accent-2) 5%, transparent) 60%,
				transparent
			),
			repeating-linear-gradient(
				45deg,
				transparent 0 6px,
				color-mix(in srgb, var(--line) 80%, transparent) 6px 7px
			);
		border: 1px solid var(--line);
		border-radius: 2px;
		overflow: hidden;
	}
	.thumb-kind {
		position: absolute;
		top: 6px;
		left: 8px;
		font-size: 10px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--dim);
	}
	.thumb-pending {
		position: absolute;
		bottom: 6px;
		right: 8px;
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--warn);
	}

	.meta {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-width: 0;
	}
	.meta-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
		flex-wrap: wrap;
	}
	.title {
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: 15px;
		color: var(--fg);
	}
	.alt {
		margin: 6px 0 12px;
		color: var(--dim);
		font-size: 12.5px;
	}
	.path, .license {
		color: var(--mute);
		font-size: 11.5px;
	}
	.path {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (max-width: 560px) {
		.frame-card { grid-template-columns: 1fr; gap: 12px; }
		.thumb { max-width: 240px; }
	}
</style>
