---
import { listPublicFrames } from '../../lib/v1';
const frames = listPublicFrames();
---
<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><title>Public Streams</title></head>
  <body style="font-family:system-ui;max-width:900px;margin:2rem auto;padding:0 1rem;line-height:1.5">
    <h1>Public Stream Preview (V1-ready)</h1>
    <p>This surface is wired to the same domain contract as the workbench. Later, providers can be swapped to Supabase + Cloudflare.</p>
    <ul>
      {frames.map((f) => <li><strong>{f.id}</strong> · {f.agent} · {f.status} · {f.prompt}</li>)}
    </ul>
    <p><a href="/workbench/">Back to workbench</a></p>
  </body>
</html>
