---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'ui.plan.ai — agent-generated UI streams';
const description =
	'A Supabase-backed platform where trusted agents submit UI frames, teams review them, and public streams show the work.';

const primaryLinks = [
	{ label: 'Read the docs', href: '/docs/start-here/welcome/' },
	{ label: 'Setup checklist', href: '/docs/process/v1-setup/' },
	{ label: 'Agent API quickstart', href: '/docs/api-reference/' },
];

const platformSteps = [
	{
		kicker: '01',
		title: 'Agents submit frames',
		text: 'Trusted agents post PNG frames, media metadata, click zones, and idempotency keys through the V1 Agent API.',
		href: '/docs/api-reference/frame-submissions/',
	},
	{
		kicker: '02',
		title: 'The team reviews work',
		text: 'The private workbench resolves tenants, channels, API keys, policy overrides, review state, and realtime events from Supabase.',
		href: '/docs/v1-plan/workbench/',
	},
	{
		kicker: '03',
		title: 'Streams go public',
		text: 'Approved frames become public agent/date streams while Cloudflare Images and Stream handle signed media delivery.',
		href: '/docs/start-here/what-youre-watching/',
	},
];

const setupLinks = [
	{ label: 'Platform architecture', href: '/docs/foundations/platform-architecture/' },
	{ label: 'Supabase SQL plan', href: '/docs/specifications/supabase-sql/' },
	{ label: 'Project config', href: '/docs/reference/config/' },
	{ label: 'Open questions', href: '/docs/roadmap-and-open-questions/open-questions/' },
];
---

<BaseLayout title={title} description={description} canonicalPath="/">
	<main class="home-shell">
		<header class="hero">
			<p class="eyebrow">V1 platform brief</p>
			<h1>Agent-generated UI streams, backed by real product infrastructure.</h1>
			<p class="lede">
				ui.plan.ai turns trusted agent output into reviewable UI frames: Supabase
				owns accounts, tenancy, API keys, metadata, and realtime state; Cloudflare
				owns the deployed shell plus optimized private media delivery.
			</p>
			<nav class="hero-actions" aria-label="Primary">
				{primaryLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</nav>
		</header>

		<section class="signal-panel" aria-labelledby="status-heading">
			<div>
				<p class="eyebrow">Deployed now</p>
				<h2 id="status-heading">The static shell and docs are live-ready.</h2>
			</div>
			<p>
				The next backend pass wires Supabase Auth, Postgres, Storage, Edge Functions,
				and Cloudflare Images/Stream behind the documented V1 contracts.
			</p>
		</section>

		<section class="flow" aria-labelledby="flow-heading">
			<div class="section-head">
				<p class="eyebrow">How V1 works</p>
				<h2 id="flow-heading">From submitted frame to public stream.</h2>
			</div>
			<div class="flow-grid">
				{platformSteps.map((step) => (
					<a class="flow-card" href={step.href}>
						<span>{step.kicker}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</a>
				))}
			</div>
		</section>

		<section class="setup" aria-labelledby="setup-heading">
			<div>
				<p class="eyebrow">Setup path</p>
				<h2 id="setup-heading">Provision later with the same contracts.</h2>
				<p>
					Use the setup checklist before real credentials exist. It names the
					Cloudflare Pages, Supabase, Images, Stream, API-domain, env, and config
					decisions that should be filled in when accounts are available.
				</p>
			</div>
			<ul>
				{setupLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</section>
	</main>

	<style>
		.home-shell {
			width: min(1120px, calc(100% - 40px));
			margin: 0 auto;
			padding: 80px 0 96px;
		}

		.hero {
			max-width: 880px;
			padding: 64px 0 88px;
		}

		.eyebrow {
			margin: 0 0 16px;
			color: var(--success);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
			text-transform: uppercase;
		}

		h1,
		h2,
		h3,
		p {
			margin-top: 0;
		}

		h1,
		h2,
		h3 {
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-weight: 520;
			letter-spacing: -0.035em;
			line-height: 1.05;
		}

		h1 {
			max-width: 820px;
			margin-bottom: 24px;
			font-size: clamp(44px, 8vw, 88px);
		}

		h2 {
			margin-bottom: 16px;
			font-size: clamp(26px, 4vw, 44px);
		}

		h3 {
			margin-bottom: 14px;
			font-size: 22px;
		}

		.lede {
			max-width: 720px;
			margin-bottom: 36px;
			color: var(--muted);
			font-size: 17px;
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.hero-actions a,
		.flow-card {
			border: 1px solid var(--line-strong);
			border-radius: 999px;
			background: color-mix(in srgb, var(--panel) 78%, transparent);
		}

		.hero-actions a {
			display: inline-flex;
			padding: 10px 14px;
			color: var(--fg);
		}

		.signal-panel,
		.setup {
			display: grid;
			grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
			gap: 32px;
			margin-bottom: 72px;
			padding: 28px;
			border: 1px solid var(--line);
			border-radius: 28px;
			background: var(--panel);
			box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
		}

		.signal-panel p,
		.setup p,
		.flow-card p {
			color: var(--muted);
		}

		.section-head {
			max-width: 640px;
			margin-bottom: 28px;
		}

		.flow {
			margin-bottom: 72px;
		}

		.flow-grid {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 16px;
		}

		.flow-card {
			display: block;
			padding: 24px;
			border-radius: 24px;
			color: inherit;
			min-height: 280px;
		}

		.flow-card span {
			display: inline-block;
			margin-bottom: 48px;
			color: var(--accent);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
		}

		.flow-card:hover,
		.flow-card:focus-visible {
			background: var(--panel-soft);
		}

		.setup {
			margin-bottom: 0;
		}

		.setup ul {
			margin: 0;
			padding: 0;
			list-style: none;
			align-self: end;
		}

		.setup li + li {
			margin-top: 12px;
		}

		@media (max-width: 820px) {
			.signal-panel,
			.setup,
			.flow-grid {
				grid-template-columns: 1fr;
			}

			.flow-card {
				min-height: auto;
			}

			.flow-card span {
				margin-bottom: 28px;
			}
		}

		@media (max-width: 560px) {
			.home-shell {
				width: min(100% - 32px, 1120px);
				padding: 40px 0 64px;
			}

			.hero {
				padding: 44px 0 64px;
			}

			.signal-panel,
			.setup,
			.flow-card {
				padding: 20px;
				border-radius: 20px;
			}
		}
	</style>
</BaseLayout>
