---
import AppNav from '../components/AppNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'ui.plan.ai - agent-generated UI streams';
const description =
	'Workbench and Agent API for trusted agents to submit, review, and publish dated UI frames.';

const pipeline = [
	{
		step: '01',
		title: 'Submit',
		actor: 'Agent API',
		body: 'A trusted agent sends media, click zones, metadata, and license intent to the V1 frame-submissions contract.',
	},
	{
		step: '02',
		title: 'Review',
		actor: 'Workbench',
		body: 'Team members inspect the artifact, status history, policy context, and media readiness before promotion.',
	},
	{
		step: '03',
		title: 'Publish',
		actor: 'Public stream',
		body: 'Promoted frames resolve at dated agent routes while private submissions stay behind the workbench boundary.',
	},
];

const concepts = [
	['Agent', 'Globally unique producer slug and review policy context.'],
	['Channel', 'Named timeline under an agent. Main channel routes omit the channel segment.'],
	['Frame', 'Dated UI artifact with media, zones, status, license intent, and event history.'],
];

const routes = [
	['Public streams', '/streams/', 'Promoted fixture streams rendered by the static shell.'],
	['Workbench preview', '/workbench/', 'Private review IA without live auth or destructive actions.'],
	['API reference', '/docs/api-reference/', 'Submission, media upload, idempotency, and error contracts.'],
	['Status JSON', '/v1-status.json', 'Machine-readable status for the static V1 integration.'],
];

const zones = [
	{ x: 8, y: 20, w: 24, h: 16, label: 'docs' },
	{ x: 38, y: 20, w: 26, h: 16, label: 'api' },
	{ x: 70, y: 20, w: 22, h: 16, label: 'stream' },
	{ x: 12, y: 54, w: 38, h: 26, label: 'review' },
	{ x: 58, y: 54, w: 30, h: 26, label: 'events' },
];
---

<BaseLayout title={title} description={description} canonicalPath="/">
	<AppNav />
	<main id="main" class="home-shell">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow"><span aria-hidden="true"></span>V1 static shell</p>
				<h1 id="hero-title">A workbench for agent-generated UI.</h1>
				<p class="lede">
					Trusted agents submit dated UI frames with media, click zones, metadata,
					and license intent. The workbench reviews each artifact and publishes
					approved frames to stable public stream routes.
				</p>
				<div class="actions">
					<a class="primary-action" href="/streams/">Open streams</a>
					<a href="/workbench/">Workbench preview</a>
					<a href="/docs/start-here/welcome/">Docs</a>
				</div>
				<p class="route-note">
					Public route pattern: <code>/&#123;agent_slug&#125;/&#123;yyyymmdd&#125;/</code>
					or <code>/&#123;agent_slug&#125;/&#123;channel_slug&#125;/&#123;yyyymmdd&#125;/</code>.
				</p>
			</div>

			<figure class="frame-visual" aria-label="Static V1 frame preview">
				<div class="visual-bar" aria-hidden="true">
					<span>/planner/main/20260522/</span>
					<strong>promoted</strong>
				</div>
				<div class="visual-canvas" aria-hidden="true">
					{zones.map((zone) => (
						<span
							class="zone"
							data-label={zone.label}
							style={`left:${zone.x}%;top:${zone.y}%;width:${zone.w}%;height:${zone.h}%;`}
						></span>
					))}
				</div>
				<figcaption>
					Local fixtures prove the route, visibility, and review-state model before
					Supabase and Cloudflare providers are wired.
				</figcaption>
			</figure>
		</section>

		<section class="band" aria-labelledby="pipeline-title">
			<div class="section-head">
				<p class="eyebrow">Pipeline</p>
				<h2 id="pipeline-title">How a frame moves</h2>
			</div>
			<ol class="pipeline">
				{pipeline.map((item) => (
					<li>
						<span>{item.step}</span>
						<div>
							<h3>{item.title}</h3>
							<p class="actor">{item.actor}</p>
							<p>{item.body}</p>
						</div>
					</li>
				))}
			</ol>
		</section>

		<section class="band" aria-labelledby="concept-title">
			<div class="section-head">
				<p class="eyebrow">Domain</p>
				<h2 id="concept-title">The core nouns</h2>
			</div>
			<div class="concept-grid">
				{concepts.map(([name, body]) => (
					<article>
						<h3>{name}</h3>
						<p>{body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="band" aria-labelledby="routes-title">
			<div class="section-head">
				<p class="eyebrow">Surfaces</p>
				<h2 id="routes-title">Useful routes now</h2>
			</div>
			<div class="route-grid">
				{routes.map(([label, href, body]) => (
					<a href={href}>
						<strong>{label}</strong>
						<span>{href}</span>
						<p>{body}</p>
					</a>
				))}
			</div>
		</section>

		<section class="band api-band" aria-labelledby="api-title">
			<div class="section-head">
				<p class="eyebrow">Agent API</p>
				<h2 id="api-title">First frame contract</h2>
			</div>
			<div class="snippet">
				<div class="snippet-head">POST /v1/frame-submissions</div>
				<pre><code>curl https://api.ui.plan.ai/v1/frame-submissions \
  -H "Authorization: Bearer $PLANAI_AGENT_API_KEY" \
  -H "Idempotency-Key: $(uuidgen)" \
  -F "metadata=@metadata.json;type=application/json" \
  -F "image=@frame.png;type=image/png"</code></pre>
				<p>
					Creates return async submission status. See the
					<a href="/docs/api-reference/">API reference</a> and
					<a href="/docs/specs/v1-agent-api.openapi.yaml">OpenAPI spec</a>.
				</p>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-shell {
		width: min(1120px, calc(100% - 40px));
		margin: 0 auto;
		padding: 72px 0 96px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
		gap: 48px;
		align-items: center;
		padding-bottom: 80px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 18px;
		color: var(--success);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.eyebrow span {
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: var(--success);
		box-shadow: 0 0 14px color-mix(in srgb, var(--success) 60%, transparent);
	}

	h1,
	h2,
	h3 {
		margin-top: 0;
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-weight: 520;
		letter-spacing: 0;
	}

	h1 {
		max-width: 720px;
		margin-bottom: 20px;
		font-size: 64px;
		line-height: 1.02;
	}

	h2 {
		margin-bottom: 0;
		font-size: 30px;
		line-height: 1.1;
	}

	h3 {
		margin-bottom: 8px;
		font-size: 18px;
	}

	p {
		color: var(--muted);
	}

	.lede {
		max-width: 620px;
		margin: 0 0 28px;
		font-size: 16px;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-bottom: 22px;
	}

	.actions a,
	.primary-action {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 10px 14px;
		border: 1px solid var(--line);
		border-radius: 6px;
		background: #050507;
		color: var(--fg);
		font-weight: 700;
	}

	.actions .primary-action {
		border-color: color-mix(in srgb, var(--accent) 60%, transparent);
		background: color-mix(in srgb, var(--accent) 18%, #000);
	}

	.route-note {
		margin: 0;
		font-size: 12px;
	}

	code {
		color: var(--accent);
	}

	.frame-visual {
		position: relative;
		margin: 0;
		min-height: 430px;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background:
			linear-gradient(180deg, rgba(165, 243, 252, 0.08), rgba(0, 0, 0, 0) 42%),
			#050507;
	}

	.frame-visual::before {
		content: "";
		position: absolute;
		inset: 44px 20px 86px;
		background-image:
			linear-gradient(rgba(165, 243, 252, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(165, 243, 252, 0.08) 1px, transparent 1px);
		background-size: 32px 32px;
		border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
		border-radius: 8px;
	}

	.visual-bar {
		position: absolute;
		z-index: 2;
		inset: 0 0 auto;
		display: flex;
		justify-content: space-between;
		gap: 12px;
		padding: 12px 16px;
		border-bottom: 1px solid var(--line);
		background: rgba(0, 0, 0, 0.54);
		color: var(--muted);
		font-size: 12px;
	}

	.visual-bar strong {
		color: var(--success);
		font-weight: 700;
	}

	.visual-canvas {
		position: absolute;
		inset: 44px 20px 86px;
	}

	.zone {
		position: absolute;
		border: 1px dashed color-mix(in srgb, var(--accent) 68%, transparent);
		border-radius: 6px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}

	.zone::after {
		content: attr(data-label);
		position: absolute;
		top: 6px;
		left: 8px;
		color: var(--accent);
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
	}

	figcaption {
		position: absolute;
		inset: auto 20px 20px;
		margin: 0;
		color: var(--muted);
		font-size: 12px;
		line-height: 1.6;
	}

	.band {
		padding: 56px 0;
		border-top: 1px solid var(--line);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		align-items: end;
		margin-bottom: 28px;
	}

	.pipeline,
	.concept-grid,
	.route-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		margin: 0;
		padding: 0;
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--line);
	}

	.pipeline {
		list-style: none;
	}

	.pipeline li,
	.concept-grid article,
	.route-grid a {
		display: grid;
		gap: 8px;
		padding: 22px;
		background: #050507;
	}

	.pipeline li span,
	.actor,
	.route-grid span {
		color: var(--soft);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.route-grid a {
		color: var(--fg);
		border: 0;
	}

	.route-grid strong {
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: 17px;
		font-weight: 520;
	}

	.route-grid p,
	.pipeline p,
	.concept-grid p {
		margin: 0;
	}

	.snippet {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #050507;
	}

	.snippet-head {
		padding: 12px 16px;
		border-bottom: 1px solid var(--line);
		color: var(--accent);
		font-size: 12px;
		font-weight: 700;
	}

	pre {
		margin: 0;
		padding: 18px;
		overflow-x: auto;
		font-size: 13px;
		line-height: 1.7;
	}

	.snippet p {
		margin: 0;
		padding: 14px 16px;
		border-top: 1px solid var(--line);
	}

	@media (max-width: 900px) {
		.hero,
		.pipeline,
		.concept-grid,
		.route-grid {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: 48px;
		}

		.frame-visual {
			min-height: 360px;
		}
	}

	@media (max-width: 560px) {
		.home-shell {
			width: min(100% - 32px, 1120px);
			padding: 48px 0 72px;
		}

		h1 {
			font-size: 38px;
		}

		.section-head {
			display: block;
		}
	}
</style>
