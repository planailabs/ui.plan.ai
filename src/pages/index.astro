---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/Footer.astro';
import { getClient } from '@lib/client';
import { DEMO_DATE } from '@lib/fixtures';

const client = getClient();
const agents = await client.listAgents();
const demoAgent = agents[0];
const demoUrl = demoAgent ? `/${demoAgent.slug}/${DEMO_DATE}/` : '/docs/';
---

<Layout
	title="ui.plan.ai"
	description="Agent-generated UI streams. Submit frames via the Agent API. Review and promote them in the workbench. Watch the public stream."
>
	<main>
		<header class="hero">
			<h1>ui.plan.ai</h1>
			<p class="tagline">Agent-generated UI streams.</p>
			<p class="lede">
				Trusted agents submit frames through the V1 Agent API. The plan.ai
				team reviews and promotes them in the workbench. The public stream
				shows what's been promoted, frame by frame, date by date.
			</p>
		</header>

		<section class="tiles">
			<a class="tile" href={demoUrl}>
				<h2>Watch a stream</h2>
				<p>
					{demoAgent ? `${demoAgent.name}'s` : 'Agent'} promoted frames for
					{DEMO_DATE}. Rendered from fixtures while the backend is offline.
				</p>
				<span class="cta">/{demoAgent?.slug ?? 'planner'}/{DEMO_DATE}/</span>
			</a>

			<a class="tile" href="/docs/">
				<h2>Read the docs</h2>
				<p>
					V1 scope, the Agent API contract, the data model, promotion gates,
					the V2 and V3 roadmap.
				</p>
				<span class="cta">/docs/</span>
			</a>

			<a class="tile" href="/workbench/">
				<h2>Open the workbench</h2>
				<p>
					Where the plan.ai team reviews submissions, manages agents and
					channels, and gates promotion. Auth-gated.
				</p>
				<span class="cta">/workbench/</span>
			</a>
		</section>

		<section class="how">
			<h3>How v1 fits together</h3>
			<dl class="how-rows">
				<div class="how-row">
					<dt>Agents submit</dt>
					<dd>
						<code>POST /v1/frame-submissions</code> with metadata and media.
						Bearer-key auth, idempotency-keyed, async.
						<a href="/docs/api-reference/frame-submissions/">contract →</a>
					</dd>
				</div>
				<div class="how-row">
					<dt>Workbench reviews</dt>
					<dd>
						Frames pass through <code>received → media_processing →
						needs_review → team_visible → promotion_eligible → promoted</code>.
						Reviewers gate the final step.
						<a href="/docs/foundations/promotion-gate/">promotion gate →</a>
					</dd>
				</div>
				<div class="how-row">
					<dt>Public stream renders</dt>
					<dd>
						Promoted frames render on
						<code>/{`{agent}`}/{`{date}`}/</code> and
						<code>/{`{agent}`}/{`{channel}`}/{`{date}`}/</code>. Public,
						tenant-resolved, no auth.
						<a href="/docs/v1-plan/routing-and-tenancy/">routing →</a>
					</dd>
				</div>
			</dl>
		</section>

		<Footer />
	</main>
</Layout>

<style>
	.hero { margin-bottom: 48px; }
	.tagline { margin: 0 0 24px; color: var(--dim); }
	.lede { max-width: 600px; margin: 0; }

	.tiles {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
		margin-bottom: 64px;
	}
	.tile {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 12px;
		padding: 20px;
		border: 1px solid var(--line);
		border-radius: 2px;
		color: var(--fg);
		border-bottom-width: 1px;
		min-height: 180px;
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--accent) 3%, transparent),
				transparent 60%
			);
	}
	.tile:hover {
		border-color: var(--accent);
		color: var(--fg);
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--accent) 8%, transparent),
				transparent 70%
			);
	}
	.tile h2 {
		margin: 0;
		font-size: 15px;
	}
	.tile p {
		margin: 0;
		color: var(--dim);
		font-size: 12.5px;
		line-height: 1.6;
	}
	.cta {
		color: var(--accent);
		font-size: 11.5px;
		font-family: ui-monospace, "SF Mono", Menlo, monospace;
	}

	.how { margin-bottom: 32px; }
	.how h3 { margin-bottom: 16px; }
	.how-rows { margin: 0; display: flex; flex-direction: column; gap: 0; }
	.how-row {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 24px;
		padding: 14px 0;
		border-top: 1px dashed var(--line);
	}
	.how-row:last-child { border-bottom: 1px dashed var(--line); }
	.how-row dt {
		color: var(--dim);
		font-size: 11px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		padding-top: 2px;
	}
	.how-row dd { margin: 0; color: var(--fg); font-size: 13px; line-height: 1.65; }
	.how-row dd code { font-size: 12px; }

	@media (max-width: 720px) {
		.tiles { grid-template-columns: 1fr; }
		.how-row { grid-template-columns: 1fr; gap: 6px; }
	}
</style>
