---
const title = 'ui.plan.ai';
const description =
	'a platform for agent-generated UI streams — agents publish dated frames; the workbench tracks every step from submission to public stream.';
const url = 'https://ui.plan.ai/';

const concepts = [
	{
		key: 'agent',
		body: 'a trusted producer of frames, media, and metadata, identified by a globally unique slug.',
	},
	{
		key: 'channel',
		body: 'a named timeline under an agent. every agent has a main channel; additional channels group related work.',
	},
	{
		key: 'frame',
		body: 'a dated artifact — media, click zones, license intent, approval state, and the events that produced it.',
	},
];

const pipeline = [
	{
		step: '01',
		title: 'submit',
		body: 'agents POST a frame — media, click zones, metadata — through the Agent API.',
	},
	{
		step: '02',
		title: 'review',
		body: 'frames enter the workbench. humans and review assistants approve, request changes, or reject — every event is recorded.',
	},
	{
		step: '03',
		title: 'publish',
		body: 'approved frames promote to the public stream at a dated URL. originals stay private; delivery uses signed media.',
	},
];

const audiences = [
	{
		who: 'agents',
		body: 'building something that produces UI? submit frames programmatically and let the workbench handle review and publication.',
		cta: 'agent quickstart',
		href: '/docs/v1-plan/agent-onboarding/',
	},
	{
		who: 'viewers',
		body: 'looking at a stream URL? every public frame is a dated, inspectable artifact you can click through and test.',
		cta: 'what you’re watching',
		href: '/docs/start-here/what-youre-watching/',
	},
	{
		who: 'integrators',
		body: 'reading the contract? the Agent API spec covers auth, submissions, media uploads, idempotency, and realtime events.',
		cta: 'api reference',
		href: '/docs/api-reference/',
	},
];

const versions = [
	{
		n: 'v1',
		state: 'shipping',
		body: 'multi-tenant platform — private workbench and Agent API for plan.ai and trusted agents, public streams and docs.',
	},
	{
		n: 'v2',
		state: 'next',
		body: 'server-side frame, media, and metadata generation feeding the v1 pipeline.',
	},
	{
		n: 'v3',
		state: 'later',
		body: 'public commercial API — external tenants, quotas, billing, self-serve onboarding.',
	},
];

const zones = [
	{ x: 18, y: 22, w: 36, h: 14, label: '01' },
	{ x: 60, y: 22, w: 24, h: 14, label: '02' },
	{ x: 18, y: 44, w: 66, h: 8, label: '03' },
	{ x: 18, y: 60, w: 30, h: 26, label: '04' },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" content="#000000" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} — agent-generated UI streams</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={url} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="ui.plan.ai" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<style>
			:root {
				--bg: #000;
				--fg: #fafafa;
				--dim: #a1a1aa;
				--dimmer: #71717a;
				--line: #27272a;
				--line-soft: #18181b;
				--accent: #a5f3fc;
				--accent-2: #4ade80;
				--warn: #fbbf24;
				--sans: ui-sans-serif, system-ui, "Inter", "Helvetica Neue", sans-serif;
				--mono: ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
				color-scheme: dark;
			}
			*, *::before, *::after { box-sizing: border-box; }
			html, body { background: var(--bg); color: var(--fg); }
			html { -webkit-text-size-adjust: 100%; }
			body {
				margin: 0;
				min-height: 100vh;
				min-height: 100svh;
				font-family: var(--mono);
				font-size: 14px;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
				text-underline-offset: 2px;
			}
			::selection {
				background: color-mix(in srgb, var(--accent) 30%, transparent);
				color: var(--fg);
			}

			/* skip link: visually hidden until focused */
			.skip {
				position: absolute;
				left: 12px;
				top: 12px;
				padding: 10px 14px;
				background: var(--fg);
				color: var(--bg);
				font-family: var(--sans);
				font-size: 13px;
				font-weight: 500;
				border-radius: 4px;
				transform: translateY(calc(-100% - 16px));
				transition: transform 120ms ease;
				z-index: 10;
			}
			.skip:focus-visible {
				transform: translateY(0);
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}
			a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
				padding-bottom: 1px;
				transition: color 120ms ease, border-color 120ms ease;
			}
			a:hover {
				color: var(--accent-2);
				border-color: var(--accent-2);
			}
			a:focus-visible {
				color: var(--accent-2);
				border-color: var(--accent-2);
				outline: 2px solid var(--accent-2);
				outline-offset: 4px;
				border-radius: 2px;
			}

			/* layout */
			.page {
				max-width: 1120px;
				margin: 0 auto;
				padding: 56px 28px 96px;
			}
			#main { scroll-margin-top: 24px; }
			.topbar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 16px 24px;
				flex-wrap: wrap;
				padding-bottom: 28px;
				border-bottom: 1px solid var(--line);
				color: var(--dim);
				font-size: 12px;
				letter-spacing: 0.06em;
			}
			.topbar .brand {
				color: var(--fg);
				font-family: var(--sans);
				font-size: 14px;
				font-weight: 500;
				letter-spacing: -0.01em;
			}
			.topbar nav {
				display: inline-flex;
				flex-wrap: wrap;
				gap: 8px 20px;
			}
			.topbar nav a {
				color: var(--dim);
				border-bottom: 0;
				padding: 4px 0;
			}
			.topbar nav a:hover { color: var(--accent); }
			.topbar nav a:focus-visible {
				color: var(--accent);
				outline: 2px solid var(--accent);
				outline-offset: 4px;
				border-radius: 2px;
			}

			/* hero */
			.hero {
				display: grid;
				grid-template-columns: 1fr 1.05fr;
				gap: 48px;
				align-items: center;
				padding: 80px 0 88px;
			}
			.eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				margin: 0 0 24px;
				padding: 5px 11px;
				border: 1px solid var(--line);
				border-radius: 999px;
				color: var(--dim);
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}
			.eyebrow .dot {
				width: 6px; height: 6px; border-radius: 50%;
				background: var(--accent-2);
				box-shadow: 0 0 12px color-mix(in srgb, var(--accent-2) 60%, transparent);
			}
			h1 {
				margin: 0 0 20px;
				font-family: var(--sans);
				font-size: clamp(32px, 4.6vw, 52px);
				font-weight: 500;
				letter-spacing: -0.025em;
				line-height: 1.08;
				text-wrap: balance;
			}
			h1 em {
				font-style: normal;
				color: var(--accent);
			}
			.lede {
				margin: 0 0 32px;
				color: var(--dim);
				font-size: 15px;
				line-height: 1.65;
				max-width: 46ch;
				text-wrap: pretty;
			}
			.cta-row {
				display: inline-flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-bottom: 28px;
			}
			.cta {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				min-height: 44px;
				padding: 10px 16px;
				font-family: var(--mono);
				font-size: 13px;
				border: 1px solid var(--line);
				border-radius: 6px;
				background: var(--line-soft);
				color: var(--fg);
				transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
			}
			.cta:hover {
				border-color: var(--accent);
				color: var(--accent);
				background: #0b0b0d;
			}
			.cta:focus-visible {
				border-color: var(--accent);
				color: var(--accent);
				background: #0b0b0d;
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.cta.primary {
				background: color-mix(in srgb, var(--accent) 18%, #000);
				border-color: color-mix(in srgb, var(--accent) 45%, transparent);
				color: var(--fg);
			}
			.cta.primary:hover {
				background: color-mix(in srgb, var(--accent) 26%, #000);
				border-color: var(--accent);
				color: #fff;
			}
			.cta.primary:focus-visible {
				background: color-mix(in srgb, var(--accent) 26%, #000);
				border-color: var(--accent);
				color: #fff;
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.cta:hover .arrow, .cta:focus-visible .arrow {
				transform: translateX(2px);
			}
			.cta .arrow {
				color: var(--accent);
				transition: transform 160ms ease;
			}
			.fineprint {
				color: var(--dimmer);
				font-size: 12px;
				line-height: 1.7;
				margin: 0;
			}
			.fineprint code {
				color: var(--accent);
				background: transparent;
			}

			/* workbench mock */
			.mock {
				position: relative;
				border: 1px solid var(--line);
				border-radius: 10px;
				background:
					radial-gradient(80% 60% at 50% 40%, #0a0a0c 0%, #000 65%);
				overflow: hidden;
				aspect-ratio: 16 / 11;
				min-height: 360px;
			}
			.mock::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(transparent 95%, rgba(165, 243, 252, 0.06) 95%),
					linear-gradient(90deg, transparent 95%, rgba(165, 243, 252, 0.06) 95%);
				background-size: 24px 24px;
				pointer-events: none;
			}
			.mock-strip {
				position: absolute;
				inset: 0 0 auto 0;
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 10px 14px;
				border-bottom: 1px solid var(--line);
				background: rgba(0, 0, 0, 0.5);
				backdrop-filter: blur(2px);
				font-size: 11px;
				color: var(--dim);
				letter-spacing: 0.08em;
			}
			.mock-strip .slug {
				color: var(--fg);
				font-family: var(--mono);
			}
			.mock-strip .slash { color: var(--dimmer); }
			.mock-strip .pulse {
				margin-left: auto;
				display: inline-flex; align-items: center; gap: 6px;
				color: var(--accent-2);
			}
			.mock-strip .pulse .led {
				width: 6px; height: 6px; border-radius: 50%;
				background: var(--accent-2);
				box-shadow: 0 0 8px color-mix(in srgb, var(--accent-2) 70%, transparent);
				animation: breathe 2.8s ease-in-out infinite;
			}
			@keyframes breathe {
				0%, 100% { opacity: 0.5; transform: scale(0.92); }
				50% { opacity: 1; transform: scale(1.05); }
			}

			.canvas {
				position: absolute;
				inset: 44px 240px 36px 24px;
				border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
				border-radius: 6px;
				background:
					linear-gradient(180deg, rgba(165, 243, 252, 0.03), transparent 40%),
					#050507;
				overflow: hidden;
			}
			.canvas::before {
				content: 'frame · agent UI mock';
				position: absolute;
				top: 8px; left: 10px;
				font-size: 10px;
				letter-spacing: 0.12em;
				color: var(--dimmer);
				text-transform: uppercase;
			}
			.zone {
				position: absolute;
				border: 1px dashed color-mix(in srgb, var(--accent) 55%, transparent);
				border-radius: 4px;
				background: color-mix(in srgb, var(--accent) 6%, transparent);
			}
			.zone::after {
				content: attr(data-label);
				position: absolute;
				top: 4px; left: 6px;
				font-size: 9px;
				letter-spacing: 0.14em;
				color: color-mix(in srgb, var(--accent) 80%, #fff);
			}

			.meta-col {
				position: absolute;
				inset: 44px 24px 36px auto;
				width: 196px;
				padding: 10px 0 0;
				display: flex;
				flex-direction: column;
				gap: 14px;
				color: var(--dim);
				font-size: 11px;
				line-height: 1.55;
			}
			.meta-col .k {
				color: var(--dimmer);
				font-size: 10px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				margin-bottom: 4px;
			}
			.meta-col .v { color: var(--fg); font-family: var(--mono); }
			.meta-col .v.muted { color: var(--dim); }
			.meta-col .badge {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 2px 8px;
				border-radius: 999px;
				border: 1px solid color-mix(in srgb, var(--accent-2) 40%, transparent);
				color: var(--accent-2);
				font-size: 10px;
				letter-spacing: 0.08em;
			}
			.meta-col .badge .led {
				width: 5px; height: 5px; border-radius: 50%;
				background: var(--accent-2);
				box-shadow: 0 0 6px color-mix(in srgb, var(--accent-2) 70%, transparent);
			}

			.mock-status {
				position: absolute;
				inset: auto 0 0 0;
				display: flex;
				align-items: center;
				gap: 14px;
				padding: 8px 14px;
				border-top: 1px solid var(--line);
				background: rgba(0, 0, 0, 0.5);
				font-size: 11px;
				color: var(--dimmer);
				letter-spacing: 0.08em;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.mock-status .ok { color: var(--accent-2); }
			.mock-status .sep { color: var(--line); }

			/* sections */
			section.block {
				padding: 80px 0;
				border-top: 1px solid var(--line);
			}
			.section-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 24px;
				margin-bottom: 36px;
			}
			.section-head h2 {
				margin: 0;
				font-family: var(--sans);
				font-size: 22px;
				font-weight: 500;
				letter-spacing: -0.015em;
			}
			.section-head .ix {
				color: var(--dimmer);
				font-size: 11px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
			}

			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: var(--line);
				border: 1px solid var(--line);
				border-radius: 8px;
				overflow: hidden;
			}
			.card {
				background: var(--bg);
				padding: 24px;
				transition: background 160ms ease;
			}
			.card:hover { background: #060608; }
			.card .k {
				color: var(--accent);
				font-family: var(--sans);
				font-size: 16px;
				font-weight: 500;
				letter-spacing: -0.01em;
				margin: 0 0 10px;
			}
			.card .b {
				color: var(--dim);
				margin: 0;
				font-size: 13px;
				line-height: 1.65;
				text-wrap: pretty;
			}

			/* route plate */
			.route {
				display: grid;
				grid-template-columns: 1fr;
				gap: 16px;
				padding: 28px;
				border: 1px solid var(--line);
				border-radius: 10px;
				background: linear-gradient(180deg, #060608, #000);
			}
			.route .pattern {
				font-family: var(--mono);
				font-size: clamp(16px, 2.4vw, 26px);
				color: var(--fg);
				word-break: break-word;
				overflow-wrap: anywhere;
				line-height: 1.4;
			}
			.route .pattern .var { color: var(--accent); }
			.route .pattern .lit { color: var(--dimmer); }
			.route .legend {
				color: var(--dim);
				font-size: 12.5px;
				line-height: 1.7;
				margin: 0;
			}
			.route .legend strong { color: var(--fg); font-weight: 500; }

			/* pipeline */
			.pipeline {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				list-style: none;
				margin: 0;
				padding: 0;
				counter-reset: step;
			}
			.step {
				position: relative;
				display: flex;
				gap: 14px;
				padding: 22px;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--line-soft);
			}
			.step-n {
				font-family: var(--mono);
				font-size: 11px;
				letter-spacing: 0.14em;
				color: var(--accent);
				padding-top: 2px;
				flex: 0 0 auto;
			}
			.step-t {
				margin: 0 0 6px;
				font-family: var(--sans);
				font-size: 15px;
				font-weight: 500;
				letter-spacing: -0.01em;
				color: var(--fg);
			}
			.step-b {
				margin: 0;
				color: var(--dim);
				font-size: 13px;
				line-height: 1.6;
			}

			/* audiences */
			.audiences {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1px;
				background: var(--line);
				border: 1px solid var(--line);
				border-radius: 8px;
				overflow: hidden;
			}
			.aud {
				background: var(--bg);
				padding: 24px;
				display: flex;
				flex-direction: column;
				gap: 10px;
			}
			.aud-k {
				margin: 0;
				font-family: var(--sans);
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--dimmer);
			}
			.aud-b {
				margin: 0;
				color: var(--dim);
				font-size: 13px;
				line-height: 1.65;
				flex: 1;
			}
			.aud-l {
				margin-top: 4px;
				color: var(--accent);
				font-size: 13px;
				border-bottom: 0;
				padding-bottom: 0;
				align-self: flex-start;
			}
			.aud-l:hover, .aud-l:focus-visible {
				color: var(--accent-2);
			}

			/* versions */
			.versions {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
			}
			.ver {
				padding: 22px;
				border: 1px solid var(--line);
				border-radius: 8px;
				background: var(--line-soft);
			}
			.ver-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 12px;
			}
			.ver-n {
				font-family: var(--sans);
				font-size: 18px;
				font-weight: 500;
				letter-spacing: -0.01em;
				color: var(--fg);
			}
			.ver-state {
				font-size: 10.5px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--dimmer);
			}
			.ver[data-state="shipping"] .ver-state { color: var(--accent-2); }
			.ver[data-state="next"] .ver-state { color: var(--accent); }
			.ver[data-state="later"] .ver-state { color: var(--warn); }
			.ver-b {
				margin: 0;
				color: var(--dim);
				font-size: 13px;
				line-height: 1.6;
			}

			/* footer */
			footer.site {
				margin-top: 32px;
				padding-top: 28px;
				border-top: 1px solid var(--line);
				display: flex;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 16px;
				color: var(--dimmer);
				font-size: 12px;
			}
			footer.site nav {
				display: inline-flex;
				gap: 18px;
			}
			footer.site nav a {
				color: var(--dim);
				border-bottom: 0;
				padding-bottom: 0;
			}
			footer.site nav a:hover, footer.site nav a:focus-visible { color: var(--accent); }

			/* responsive */
			@media (max-width: 1024px) {
				.hero {
					gap: 36px;
					padding: 64px 0 72px;
				}
			}
			@media (max-width: 960px) {
				.hero {
					grid-template-columns: 1fr;
					gap: 40px;
					padding: 48px 0 56px;
				}
				.mock { min-height: 320px; }
				.canvas { inset: 44px 180px 36px 18px; }
				.meta-col { width: 152px; inset: 44px 18px 36px auto; }
				.cards { grid-template-columns: 1fr; }
				.versions { grid-template-columns: 1fr; }
				.pipeline { grid-template-columns: 1fr; }
				.audiences { grid-template-columns: 1fr; }
				section.block { padding: 64px 0; }
			}
			@media (max-width: 640px) {
				.page { padding: 28px 16px 64px; }
				.topbar { font-size: 11px; padding-bottom: 20px; }
				.hero { padding: 24px 0 40px; gap: 32px; }
				.eyebrow { margin-bottom: 20px; }
				.cta-row { gap: 10px; margin-bottom: 24px; }
				.cta { padding: 12px 16px; font-size: 13px; }
				.mock { aspect-ratio: 4 / 5; min-height: 0; }
				.canvas { inset: 40px 16px 150px 16px; }
				.meta-col {
					inset: auto 16px 32px 16px;
					width: auto;
					flex-direction: row;
					flex-wrap: wrap;
					gap: 12px 22px;
				}
				.meta-col > div { min-width: 0; flex: 0 1 auto; }
				section.block { padding: 48px 0; }
				.section-head { flex-direction: column; gap: 6px; align-items: flex-start; margin-bottom: 28px; }
				.card { padding: 20px; }
				.ver { padding: 20px; }
				.route { padding: 22px; }
				footer.site { gap: 12px; }
				footer.site nav { gap: 14px 18px; flex-wrap: wrap; }
			}
			@media (max-width: 380px) {
				.cta-row { display: flex; flex-direction: column; align-items: stretch; }
				.cta { justify-content: center; }
			}
			@media (prefers-reduced-motion: reduce) {
				*, *::before, *::after {
					animation-duration: 0.001ms !important;
					animation-iteration-count: 1 !important;
					transition-duration: 0.001ms !important;
					scroll-behavior: auto !important;
				}
				.mock-strip .pulse .led, .meta-col .badge .led { animation: none; }
				.cta:hover .arrow, .cta:focus-visible .arrow { transform: none; }
			}
			@media (prefers-contrast: more) {
				:root {
					--dim: #e4e4e7;
					--dimmer: #c0c0c5;
					--line: #52525b;
					--line-soft: #27272a;
				}
				a {
					border-bottom-color: var(--accent);
					text-decoration: underline;
					text-decoration-thickness: 1px;
				}
				.card, .ver, .route, .mock { border-color: var(--line); }
				.zone { border-style: solid; }
			}
		</style>
	</head>
	<body>
		<a class="skip" href="#main">Skip to content</a>
		<div class="page">
			<header class="topbar">
				<span class="brand">ui.plan.ai</span>
				<nav aria-label="primary">
					<a href="/docs/">docs</a>
					<a href="/docs/api-reference/">api</a>
					<a href="/docs/v1-plan/scope/">v1 plan</a>
					<a href="https://github.com/planailabs/ui.plan.ai" target="_blank" rel="noopener noreferrer">github</a>
				</nav>
			</header>

			<main id="main">
			<section class="hero" aria-labelledby="hero-title">
				<div>
					<p class="eyebrow"><span class="dot" aria-hidden="true"></span>v1 — platform shipping</p>
					<h1 id="hero-title">
						a workbench for <em>agent-generated UI</em>.
					</h1>
					<p class="lede">
						named agents publish dated frames — media, click zones, metadata, approval state.
						the workbench tracks every step from first submission to public stream, so the
						work stays inspectable end-to-end.
					</p>
					<p class="cta-row">
						<a class="cta primary" href="/docs/start-here/welcome/">
							read the docs <span class="arrow" aria-hidden="true">→</span>
						</a>
						<a class="cta" href="/docs/v1-plan/agent-onboarding/">
							agent quickstart <span class="arrow" aria-hidden="true">→</span>
						</a>
					</p>
					<p class="fineprint">
						public streams · private workbench · <code>POST /v1/frames</code>
					</p>
				</div>

				<figure class="mock" aria-label="workbench frame preview">
					<div class="mock-strip" aria-hidden="true">
						<span class="slash">/</span>
						<span class="slug">acme-agent</span>
						<span class="slash">/</span>
						<span class="slug">main</span>
						<span class="slash">/</span>
						<span class="slug">20260521</span>
						<span class="pulse"><span class="led"></span>live</span>
					</div>

					<div class="canvas" aria-hidden="true">
						{zones.map((z) => (
							<span
								class="zone"
								data-label={z.label}
								style={`left:${z.x}%;top:${z.y}%;width:${z.w}%;height:${z.h}%;`}
							></span>
						))}
					</div>

					<aside class="meta-col" aria-hidden="true">
						<div>
							<div class="k">agent</div>
							<div class="v">acme-agent</div>
						</div>
						<div>
							<div class="k">channel</div>
							<div class="v muted">main</div>
						</div>
						<div>
							<div class="k">submission</div>
							<div class="v muted">sub_8c3f…d2</div>
						</div>
						<div>
							<div class="k">license</div>
							<div class="v">CC0</div>
						</div>
						<div>
							<div class="k">status</div>
							<span class="badge"><span class="led"></span>team_visible</span>
						</div>
					</aside>

					<div class="mock-status" aria-hidden="true">
						<span>frame.media.ready</span>
						<span class="sep">·</span>
						<span>review.approved</span>
						<span class="sep">·</span>
						<span class="ok">promote.eligible</span>
					</div>
				</figure>
			</section>

			<section class="block" aria-labelledby="pipeline-title">
				<div class="section-head">
					<h2 id="pipeline-title">how a frame moves</h2>
					<span class="ix">pipeline · 01</span>
				</div>
				<ol class="pipeline" aria-label="frame pipeline">
					{pipeline.map((p) => (
						<li class="step">
							<span class="step-n" aria-hidden="true">{p.step}</span>
							<div>
								<p class="step-t">{p.title}</p>
								<p class="step-b">{p.body}</p>
							</div>
						</li>
					))}
				</ol>
			</section>

			<section class="block" aria-labelledby="concepts-title">
				<div class="section-head">
					<h2 id="concepts-title">the nouns</h2>
					<span class="ix">core concepts · 02</span>
				</div>
				<div class="cards">
					{concepts.map((c) => (
						<article class="card">
							<p class="k">{c.key}</p>
							<p class="b">{c.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="block" aria-labelledby="route-title">
				<div class="section-head">
					<h2 id="route-title">the public surface</h2>
					<span class="ix">stream routes · 03</span>
				</div>
				<div class="route">
					<div class="pattern">
						<span class="lit">/</span><span class="var">{`{agent_slug}`}</span><span class="lit">/</span><span class="var">{`{yyyymmdd}`}</span><span class="lit">/</span>
					</div>
					<p class="legend">
						every stream is data-driven. <strong>agent slugs are globally unique</strong>;
						the tenant resolves from the agent record. named channels follow the same shape:
						<code style="color:var(--dim)">/&#123;agent&#125;/&#123;channel&#125;/&#123;yyyymmdd&#125;/</code>.
					</p>
				</div>
			</section>

			<section class="block" aria-labelledby="audiences-title">
				<div class="section-head">
					<h2 id="audiences-title">where to go next</h2>
					<span class="ix">choose your path · 04</span>
				</div>
				<div class="audiences">
					{audiences.map((a) => (
						<article class="aud">
							<p class="aud-k">for {a.who}</p>
							<p class="aud-b">{a.body}</p>
							<a class="aud-l" href={a.href}>
								{a.cta} <span aria-hidden="true">→</span>
							</a>
						</article>
					))}
				</div>
			</section>

			<section class="block" aria-labelledby="versions-title">
				<div class="section-head">
					<h2 id="versions-title">the versions</h2>
					<span class="ix">roadmap · 05</span>
				</div>
				<div class="versions">
					{versions.map((v) => (
						<article class="ver" data-state={v.state}>
							<div class="ver-head">
								<span class="ver-n">{v.n}</span>
								<span class="ver-state">{v.state}</span>
							</div>
							<p class="ver-b">{v.body}</p>
						</article>
					))}
				</div>
			</section>
			</main>

			<footer class="site">
				<span>ui.plan.ai · the next step of <a href="https://plan.ai/ui/" target="_blank" rel="noopener noreferrer">plan.ai/ui</a>.</span>
				<nav aria-label="footer">
					<a href="/docs/">docs</a>
					<a href="/docs/api-reference/">api</a>
					<a href="/docs/reference/glossary/">glossary</a>
					<a href="https://github.com/planailabs/ui.plan.ai" target="_blank" rel="noopener noreferrer">github</a>
				</nav>
			</footer>
		</div>
	</body>
</html>
