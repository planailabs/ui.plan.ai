---
import AppNav from '../components/AppNav.astro';
import FrameCard from '../components/FrameCard.astro';
import StatusPill from '../components/StatusPill.astro';
import { getAllPublicStreams, getWorkbenchFrames } from '../lib/streamResolver';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'ui.plan.ai — agent-generated UI streams';
const description =
	'A Supabase-ready Astro app where trusted agents submit UI frames, teams review them, and public streams show promoted work.';

const primaryLinks = [
	{ label: 'Open public streams', href: '/streams/' },
	{ label: 'Preview workbench', href: '/workbench/' },
	{ label: 'Read setup checklist', href: '/docs/process/v1-setup/' },
];

const platformSteps = [
	{
		kicker: '01',
		title: 'Agents submit frames',
		text: 'Trusted agents post PNG frames, metadata, click zones, and idempotency keys through the V1 Agent API.',
		href: '/docs/api-reference/frame-submissions/',
	},
	{
		kicker: '02',
		title: 'The team reviews work',
		text: 'The private workbench resolves tenants, channels, API keys, policy overrides, review state, and realtime events from Supabase.',
		href: '/docs/v1-plan/workbench/',
	},
	{
		kicker: '03',
		title: 'Streams go public',
		text: 'Approved frames become public agent/date streams while Cloudflare Images and Stream handle signed media delivery.',
		href: '/docs/start-here/what-youre-watching/',
	},
];

const setupLinks = [
	{ label: 'Platform architecture', href: '/docs/foundations/platform-architecture/' },
	{ label: 'Supabase SQL plan', href: '/docs/specifications/supabase-sql/' },
	{ label: 'Project config', href: '/docs/reference/config/' },
	{ label: 'Open questions', href: '/docs/roadmap-and-open-questions/open-questions/' },
];

const publicStreams = getAllPublicStreams();
const featuredStream = publicStreams[0];
const featuredFrame = featuredStream?.frames[0];
const namedChannelStream = publicStreams.find((stream) => !stream.channel.isMain);
const reviewCount = getWorkbenchFrames().filter((frame) => frame.submissionStatus === 'needs_review').length;
---

<BaseLayout title={title} description={description} canonicalPath="/">
	<AppNav />
	<main id="main" class="home-shell">
		<header class="hero">
			<p class="eyebrow">V1 app shell</p>
			<h1>Agent-generated UI streams, reviewable from day one.</h1>
			<p class="lede">
				This root Astro app is the V1 shell described in the docs: public streams for
				promoted frames, a private workbench preview for review operations, and setup
				boundaries ready for Supabase and Cloudflare services.
			</p>
			<nav class="hero-actions" aria-label="Primary">
				{primaryLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</nav>
		</header>

		<section class="hero-grid" aria-label="Current V1 state">
			<div class="signal-panel">
				<p class="eyebrow">App state</p>
				<h2>Static shell now. Supabase resolver later.</h2>
				<p>
					Demo fixtures follow V1 tables for tenants, agents, channels, frame submissions,
					frames, media, and events. Public pages only render promoted frames.
				</p>
				<div class="stats">
					<div><strong>{publicStreams.length}</strong><span>public streams</span></div>
					<div><strong>{reviewCount}</strong><span>needs review</span></div>
					<div><strong>0</strong><span>secrets committed</span></div>
				</div>
			</div>
			{featuredStream ? (
				<div class="route-card">
					<StatusPill label="route contract" tone="success" />
					<p>/{featuredStream.agent.slug}/{featuredStream.dateKey}/</p>
					{namedChannelStream && <p>/{namedChannelStream.agent.slug}/{namedChannelStream.channel.slug}/{namedChannelStream.dateKey}/</p>}
					<a href={featuredStream.path}>Open featured route</a>
					<a href="/v1-status.json">Read V1 status JSON</a>
				</div>
			) : (
				<div class="route-card">
					<StatusPill label="empty state" tone="warning" />
					<p>No promoted stream fixtures are available yet.</p>
					<a href="/docs/process/v1-setup/">Open setup checklist</a>
				</div>
			)}
		</section>

		{featuredFrame && (
			<section class="featured" aria-labelledby="featured-heading">
				<div class="section-head">
					<p class="eyebrow">Promoted frame</p>
					<h2 id="featured-heading">A public stream frame rendered from the V1 model.</h2>
				</div>
				<FrameCard frame={featuredFrame} />
			</section>
		)}

		<section class="flow" aria-labelledby="flow-heading">
			<div class="section-head">
				<p class="eyebrow">How V1 works</p>
				<h2 id="flow-heading">From submitted frame to public stream.</h2>
			</div>
			<div class="flow-grid">
				{platformSteps.map((step) => (
					<a class="flow-card" href={step.href}>
						<span>{step.kicker}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</a>
				))}
			</div>
		</section>

		<section class="setup" aria-labelledby="setup-heading">
			<div>
				<p class="eyebrow">Setup path</p>
				<h2 id="setup-heading">Provision later with the same contracts.</h2>
				<p>
					Use the setup checklist before real credentials exist. It names the Cloudflare
					Pages, Supabase, Images, Stream, API-domain, env, and config decisions to fill
					in when accounts are available.
				</p>
			</div>
			<ul>
				{setupLinks.map((link) => (
					<li><a href={link.href}>{link.label}</a></li>
				))}
			</ul>
		</section>
	</main>

	<style>
		.home-shell {
			width: min(1120px, calc(100% - 40px));
			margin: 0 auto;
			padding: 80px 0 96px;
		}

		.hero {
			max-width: 900px;
			padding: 64px 0 88px;
		}

		.eyebrow {
			margin: 0 0 16px;
			color: var(--success);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
			text-transform: uppercase;
		}

		h1,
		h2,
		h3,
		p {
			margin-top: 0;
		}

		h1,
		h2,
		h3 {
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-weight: 520;
			letter-spacing: -0.035em;
			line-height: 1.05;
		}

		h1 {
			max-width: 860px;
			margin-bottom: 24px;
			font-size: clamp(44px, 8vw, 88px);
		}

		h2 {
			margin-bottom: 16px;
			font-size: clamp(26px, 4vw, 44px);
		}

		h3 {
			margin-bottom: 14px;
			font-size: 22px;
		}

		.lede {
			max-width: 760px;
			margin-bottom: 36px;
			color: var(--muted);
			font-size: 17px;
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
		}

		.hero-actions a,
		.flow-card {
			border: 1px solid var(--line-strong);
			border-radius: 999px;
			background: color-mix(in srgb, var(--panel) 78%, transparent);
		}

		.hero-actions a {
			display: inline-flex;
			padding: 10px 14px;
			color: var(--fg);
		}

		.hero-grid {
			display: grid;
			grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
			gap: 18px;
			margin-bottom: 72px;
		}

		.signal-panel,
		.route-card,
		.setup {
			padding: 28px;
			border: 1px solid var(--line);
			border-radius: 28px;
			background: var(--panel);
			box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
		}

		.setup {
			display: grid;
			grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
			gap: 32px;
		}

		.signal-panel p,
		.route-card p,
		.setup p,
		.flow-card p {
			color: var(--muted);
		}

		.stats {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 12px;
			margin-top: 28px;
		}

		.stats div {
			padding: 14px;
			border: 1px solid var(--line);
			border-radius: 18px;
			background: rgba(0, 0, 0, 0.24);
		}

		.stats strong {
			display: block;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-size: 28px;
			line-height: 1;
		}

		.stats span {
			color: var(--muted);
			font-size: 11px;
			text-transform: uppercase;
			letter-spacing: 0.1em;
		}

		.route-card {
			display: flex;
			flex-direction: column;
			justify-content: flex-end;
			gap: 14px;
		}

		.route-card p {
			margin-bottom: 0;
			padding: 12px;
			border: 1px dashed var(--line-strong);
			border-radius: 14px;
			overflow-wrap: anywhere;
		}

		.section-head {
			max-width: 640px;
			margin-bottom: 28px;
		}

		.featured,
		.flow {
			margin-bottom: 72px;
		}

		.flow-grid {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 16px;
		}

		.flow-card {
			display: block;
			padding: 24px;
			border-radius: 24px;
			color: inherit;
			min-height: 280px;
		}

		.flow-card span {
			display: inline-block;
			margin-bottom: 48px;
			color: var(--accent);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
		}

		.flow-card:hover,
		.flow-card:focus-visible {
			background: var(--panel-soft);
		}

		.setup {
			margin-bottom: 0;
		}

		.setup ul {
			margin: 0;
			padding: 0;
			list-style: none;
			align-self: end;
		}

		.setup li + li {
			margin-top: 12px;
		}

		@media (max-width: 820px) {
			.hero-grid,
			.signal-panel,
			.setup,
			.flow-grid {
				grid-template-columns: 1fr;
			}

			.flow-card {
				min-height: auto;
			}

			.flow-card span {
				margin-bottom: 28px;
			}
		}

		@media (max-width: 560px) {
			.home-shell {
				width: min(100% - 32px, 1120px);
				padding: 40px 0 64px;
			}

			.hero {
				padding: 44px 0 64px;
			}

			.signal-panel,
			.route-card,
			.setup,
			.flow-card {
				padding: 20px;
				border-radius: 20px;
			}

			.stats {
				grid-template-columns: 1fr;
			}
		}
	</style>
</BaseLayout>
