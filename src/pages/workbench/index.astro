---
import AppNav from '../../components/AppNav.astro';
import FrameCard from '../../components/FrameCard.astro';
import StatusPill from '../../components/StatusPill.astro';
import { getFrameContext, getWorkbenchFrames } from '../../data/v1Demo';
import BaseLayout from '../../layouts/BaseLayout.astro';

const frames = getWorkbenchFrames();
const reviewQueue = frames.filter((frame) => frame.submissionStatus === 'needs_review');
const promotedCount = frames.filter((frame) => frame.frameStatus === 'promoted').length;
const title = 'Workbench preview — ui.plan.ai';
const description = 'Static preview of the private V1 workbench review surface.';
---

<BaseLayout title={title} description={description} canonicalPath="/workbench/" noindex>
	<AppNav />
	<main class="workbench-shell">
		<header class="intro">
			<div>
				<p class="eyebrow">Private surface preview</p>
				<h1>Workbench review queue.</h1>
				<p>
					This static page previews the authenticated V1 workbench shape. Real team
					sessions, API-key actions, RLS, and realtime updates wait for Supabase.
				</p>
			</div>
			<div class="auth-note">
				<StatusPill label="mock only" tone="warning" />
				<span>no live auth</span>
				<span>no destructive actions</span>
				<span>no secrets displayed</span>
			</div>
		</header>

		<section class="ops-grid" aria-label="Workbench summary">
			<div><strong>{frames.length}</strong><span>submissions</span></div>
			<div><strong>{reviewQueue.length}</strong><span>needs review</span></div>
			<div><strong>{promotedCount}</strong><span>promoted</span></div>
			<div><strong>3</strong><span>policy layers</span></div>
		</section>

		<section class="layout-grid">
			<div class="queue-panel">
				<div class="panel-head">
					<p class="eyebrow">Stream review</p>
					<h2>Submission queue</h2>
				</div>
				<div class="queue-list">
					{frames.map((frame) => {
						const context = getFrameContext(frame);
						const streamPath = context.channel.isMain
							? `/${context.agent.slug}/${frame.dateKey}/`
							: `/${context.agent.slug}/${context.channel.slug}/${frame.dateKey}/`;
						return (
							<article class="queue-item">
								<div>
									<h3>{frame.title}</h3>
									<p>{context.agent.slug} / {context.channel.slug} / {frame.dateKey}</p>
								</div>
								<div class="queue-status">
									<StatusPill label={frame.submissionStatus} tone={frame.submissionStatus === 'needs_review' ? 'warning' : 'muted'} />
									{frame.frameStatus === 'promoted' && <a href={streamPath}>public route</a>}
								</div>
							</article>
						);
					})}
				</div>
			</div>

			<div class="detail-panel">
				<div class="panel-head">
					<p class="eyebrow">Frame detail</p>
					<h2>Current review item</h2>
				</div>
				<FrameCard frame={reviewQueue[0] ?? frames[0]} compact />
			</div>
		</section>

		<section class="settings-grid" aria-label="Workbench settings preview">
			<div class="settings-card">
				<p class="eyebrow">Approval settings</p>
				<h2>Effective inherited values first.</h2>
				<dl>
					<div><dt>Global default</dt><dd>requires review</dd></div>
					<div><dt>Agent override</dt><dd>Planner keeps manual promotion</dd></div>
					<div><dt>Channel override</dt><dd>Review channel requires explicit team action</dd></div>
				</dl>
			</div>
			<div class="settings-card">
				<p class="eyebrow">API keys</p>
				<h2>Scoped key metadata, no secret values.</h2>
				<dl>
					<div><dt>Prefix</dt><dd>plai_demo_7QK</dd></div>
					<div><dt>Scopes</dt><dd>frame:write, media:write</dd></div>
					<div><dt>Last used</dt><dd>2026-05-22 10:04 UTC</dd></div>
				</dl>
			</div>
		</section>
	</main>

	<style>
		.workbench-shell {
			width: min(1220px, calc(100% - 40px));
			margin: 0 auto;
			padding: 64px 0 96px;
		}

		.intro {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 28px;
			align-items: end;
			margin-bottom: 32px;
		}

		.eyebrow {
			margin: 0 0 14px;
			color: var(--success);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
			text-transform: uppercase;
		}

		h1,
		h2,
		h3 {
			margin-top: 0;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-weight: 520;
			letter-spacing: -0.04em;
			line-height: 1.05;
		}

		h1 {
			margin-bottom: 18px;
			font-size: clamp(42px, 7vw, 76px);
		}

		h2 {
			margin-bottom: 0;
			font-size: 28px;
		}

		h3 {
			margin: 0 0 6px;
			font-size: 16px;
			letter-spacing: -0.01em;
		}

		p,
		dd {
			color: var(--muted);
		}

		.intro p {
			max-width: 760px;
		}

		.auth-note,
		.ops-grid,
		.queue-panel,
		.detail-panel,
		.settings-card {
			border: 1px solid var(--line);
			border-radius: 26px;
			background: var(--panel);
		}

		.auth-note {
			display: grid;
			gap: 8px;
			min-width: 220px;
			padding: 18px;
			color: var(--muted);
			font-size: 12px;
		}

		.ops-grid {
			display: grid;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 12px;
			margin-bottom: 18px;
			padding: 14px;
		}

		.ops-grid div {
			padding: 16px;
			border: 1px solid var(--line);
			border-radius: 18px;
			background: rgba(0, 0, 0, 0.22);
		}

		.ops-grid strong {
			display: block;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-size: 30px;
			line-height: 1;
		}

		.ops-grid span {
			color: var(--muted);
			font-size: 11px;
			letter-spacing: 0.1em;
			text-transform: uppercase;
		}

		.layout-grid {
			display: grid;
			grid-template-columns: minmax(320px, 0.92fr) minmax(0, 1.08fr);
			gap: 18px;
			margin-bottom: 18px;
		}

		.queue-panel,
		.detail-panel,
		.settings-card {
			padding: 20px;
		}

		.panel-head {
			margin-bottom: 18px;
		}

		.queue-list {
			display: grid;
			gap: 10px;
		}

		.queue-item {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 14px;
			padding: 14px;
			border: 1px solid var(--line);
			border-radius: 18px;
			background: rgba(0, 0, 0, 0.2);
		}

		.queue-item p {
			margin: 0;
			font-size: 12px;
		}

		.queue-status {
			display: grid;
			justify-items: end;
			gap: 8px;
			font-size: 12px;
		}

		.settings-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 18px;
		}

		dl {
			display: grid;
			gap: 12px;
			margin: 18px 0 0;
		}

		dt {
			color: var(--soft);
			font-size: 11px;
			letter-spacing: 0.14em;
			text-transform: uppercase;
		}

		dd {
			margin: 4px 0 0;
		}

		@media (max-width: 920px) {
			.intro,
			.layout-grid,
			.settings-grid {
				grid-template-columns: 1fr;
			}

			.ops-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

		@media (max-width: 560px) {
			.workbench-shell {
				width: min(100% - 32px, 1220px);
				padding: 48px 0 72px;
			}

			.ops-grid,
			.queue-item {
				grid-template-columns: 1fr;
			}

			.queue-status {
				justify-items: start;
			}
		}
	</style>
</BaseLayout>
