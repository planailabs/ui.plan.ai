---
import AppNav from '../../components/AppNav.astro';
import FrameCard from '../../components/FrameCard.astro';
import StreamHeader from '../../components/StreamHeader.astro';
import { formatDateKey, getAllPublicStreams } from '../../data/v1Demo';
import BaseLayout from '../../layouts/BaseLayout.astro';

const streams = getAllPublicStreams();
const title = 'Public streams — ui.plan.ai';
const description = 'Promoted V1 agent-generated UI streams rendered by the static Astro shell.';
---

<BaseLayout title={title} description={description} canonicalPath="/streams/">
	<AppNav />
	<main class="page-shell">
		<header class="intro">
			<p class="eyebrow">Public streams</p>
			<h1>Promoted frames only.</h1>
			<p>
				This index exposes the public side of the V1 contract. Workbench-only frames
				stay out of these streams until they become promoted.
			</p>
		</header>

		<div class="stream-list">
			{streams.map((stream) => (
				<section class="stream-preview" aria-labelledby={`${stream.agent.slug}-${stream.channel.slug}-${stream.dateKey}`}>
					<StreamHeader stream={stream} />
					<h2 id={`${stream.agent.slug}-${stream.channel.slug}-${stream.dateKey}`}>
						<a href={stream.path}>{stream.path}</a>
					</h2>
					<p class="stream-date">Resolved date: {formatDateKey(stream.dateKey)}</p>
					<FrameCard frame={stream.frames[0]} compact />
				</section>
			))}
		</div>
	</main>

	<style>
		.page-shell {
			width: min(1120px, calc(100% - 40px));
			margin: 0 auto;
			padding: 72px 0 96px;
		}

		.intro {
			max-width: 760px;
			margin-bottom: 48px;
		}

		.eyebrow {
			margin: 0 0 16px;
			color: var(--success);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.18em;
			text-transform: uppercase;
		}

		h1,
		h2 {
			margin-top: 0;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-weight: 520;
			letter-spacing: -0.04em;
			line-height: 1.05;
		}

		h1 {
			margin-bottom: 18px;
			font-size: clamp(42px, 7vw, 76px);
		}

		h2 {
			margin: -8px 0 8px;
			font-size: 18px;
			letter-spacing: -0.01em;
		}

		p {
			color: var(--muted);
		}

		.stream-list {
			display: grid;
			gap: 28px;
		}

		.stream-preview {
			padding: 24px;
			border: 1px solid var(--line);
			border-radius: 30px;
			background: var(--panel);
		}

		.stream-date {
			margin: 0 0 18px;
			font-size: 12px;
		}

		@media (max-width: 560px) {
			.page-shell {
				width: min(100% - 32px, 1120px);
				padding: 48px 0 72px;
			}

			.stream-preview {
				padding: 16px;
				border-radius: 24px;
			}
		}
	</style>
</BaseLayout>
