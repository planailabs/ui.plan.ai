---
import AppNav from '../../../../components/AppNav.astro';
import FrameCard from '../../../../components/FrameCard.astro';
import StreamHeader from '../../../../components/StreamHeader.astro';
import { getPublicChannelStreams, type ResolvedStream } from '../../../../data/v1Demo';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
	return getPublicChannelStreams().map((stream) => ({
		params: {
			agentSlug: stream.agent.slug,
			channelSlug: stream.channel.slug,
			dateKey: stream.dateKey,
		},
		props: { stream },
	}));
}

interface Props {
	stream: ResolvedStream;
}

const { stream } = Astro.props;
const title = `${stream.agent.name} ${stream.channel.name} ${stream.dateKey} — ui.plan.ai`;
const description = `${stream.agent.name} public ${stream.channel.slug} channel stream for ${stream.dateKey}.`;
---

<BaseLayout title={title} description={description} canonicalPath={stream.path}>
	<AppNav />
	<main class="stream-shell">
		<StreamHeader stream={stream} />
		<div class="frames">
			{stream.frames.map((frame) => (
				<FrameCard frame={frame} />
			))}
		</div>
	</main>

	<style>
		.stream-shell {
			width: min(1120px, calc(100% - 40px));
			margin: 0 auto;
			padding: 72px 0 96px;
		}

		.frames {
			display: grid;
			gap: 24px;
		}

		@media (max-width: 560px) {
			.stream-shell {
				width: min(100% - 32px, 1120px);
				padding: 48px 0 72px;
			}
		}
	</style>
</BaseLayout>
