---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - ui.plan.ai" description="No ui.plan.ai page found at this route." canonicalPath="/404/" noindex bodyClass="not-found">
	<main id="main" class="not-found-shell">
		<p class="eyebrow"><span aria-hidden="true"></span>Route not found</p>
		<h1>404</h1>
		<p class="message">No frame exists at this path.</p>
		<p>
			Public streams resolve at <code>/&#123;agent_slug&#125;/&#123;yyyymmdd&#125;/</code>
			or <code>/&#123;agent_slug&#125;/&#123;channel_slug&#125;/&#123;yyyymmdd&#125;/</code>.
		</p>
		<nav aria-label="Recovery">
			<a href="/">Home</a>
			<a href="/streams/">Streams</a>
			<a href="/docs/start-here/welcome/">Docs</a>
			<a href="/docs/api-reference/">API</a>
		</nav>
	</main>
</BaseLayout>

<style>
	.not-found-shell {
		width: min(520px, calc(100% - 40px));
		margin: 0 auto;
		padding: 48px 0;
		text-align: center;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 24px;
		color: var(--success);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.eyebrow span {
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: var(--success);
		box-shadow: 0 0 14px color-mix(in srgb, var(--success) 60%, transparent);
	}

	h1 {
		margin: 0 0 12px;
		font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
		font-size: 76px;
		font-weight: 520;
		letter-spacing: 0;
		line-height: 1;
	}

	p {
		margin: 0 auto 14px;
		color: var(--muted);
		line-height: 1.7;
	}

	.message {
		color: var(--fg);
		font-size: 18px;
		font-weight: 700;
	}

	code {
		color: var(--accent);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 16px;
		margin-top: 28px;
	}
</style>
