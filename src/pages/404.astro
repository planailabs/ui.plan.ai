---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppNav from '../components/AppNav.astro';
---

<BaseLayout title="404 — ui.plan.ai" description="Page not found." canonicalPath="/404/" noindex>
	<AppNav />
	<main id="main">
		<p class="code" aria-hidden="true">404</p>
		<h1>Page not found.</h1>
		<p class="msg">page not found.</p>
		<nav class="links" aria-label="Recovery links">
			<a href="/">home</a>
			<a href="/streams/">streams</a>
			<a href="/docs/start-here/welcome/">docs</a>
		</nav>
	</main>

	<style>
		main {
			min-height: calc(100vh - 96px);
			display: grid;
			place-content: center;
			text-align: center;
			padding: 32px;
			max-width: 480px;
			margin: 0 auto;
		}

		.code {
			margin: 0 0 12px;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-size: 64px;
			font-weight: 520;
			letter-spacing: -0.04em;
			line-height: 1;
		}

		h1 {
			margin: 0 0 12px;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-size: 28px;
			font-weight: 520;
			letter-spacing: -0.03em;
		}

		.msg {
			margin: 0 0 28px;
			color: var(--muted);
		}

		.links {
			margin: 0;
			display: inline-flex;
			gap: 20px;
		}
	</style>
</BaseLayout>
