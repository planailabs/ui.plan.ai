---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — ui.plan.ai" description="Page not found." canonicalPath="/404/" noindex bodyClass="not-found">
	<main>
		<p class="code">404</p>
		<p class="msg">page not found.</p>
		<p class="links">
			<a href="/">home</a>
			<a href="/docs/start-here/welcome/">docs</a>
		</p>
	</main>

	<style>
		main {
			text-align: center;
			padding: 32px;
			max-width: 480px;
		}

		.code {
			margin: 0 0 12px;
			font-family: ui-sans-serif, system-ui, "Inter", sans-serif;
			font-size: 64px;
			font-weight: 520;
			letter-spacing: -0.04em;
			line-height: 1;
		}

		.msg {
			margin: 0 0 28px;
			color: var(--muted);
		}

		.links {
			margin: 0;
			display: inline-flex;
			gap: 20px;
		}
	</style>
</BaseLayout>
