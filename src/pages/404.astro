---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" content="#000000" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="noindex" />
		<title>404 — ui.plan.ai</title>
		<style>
			:root {
				--bg: #000;
				--fg: #fafafa;
				--dim: #a1a1aa;
				--dimmer: #71717a;
				--line: #27272a;
				--accent: #a5f3fc;
				--accent-2: #4ade80;
				--sans: ui-sans-serif, system-ui, "Inter", sans-serif;
				--mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
				color-scheme: dark;
			}
			*, *::before, *::after { box-sizing: border-box; }
			html, body { background: var(--bg); color: var(--fg); }
			html { -webkit-text-size-adjust: 100%; }
			body {
				margin: 0;
				min-height: 100vh;
				min-height: 100svh;
				display: grid;
				place-items: center;
				font-family: var(--mono);
				font-size: 14px;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
			}
			::selection {
				background: color-mix(in srgb, var(--accent) 30%, transparent);
				color: var(--fg);
			}
			main {
				text-align: center;
				padding: 32px 24px;
				max-width: 520px;
				width: 100%;
			}
			.status {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 5px 11px;
				border: 1px solid var(--line);
				border-radius: 999px;
				color: var(--dimmer);
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				margin-bottom: 28px;
			}
			.status .dot {
				width: 6px; height: 6px; border-radius: 50%;
				background: var(--accent-2);
				box-shadow: 0 0 8px color-mix(in srgb, var(--accent-2) 60%, transparent);
			}
			.code {
				margin: 0 0 12px;
				font-family: var(--sans);
				font-size: clamp(56px, 12vw, 80px);
				font-weight: 500;
				letter-spacing: -0.04em;
				line-height: 1;
			}
			.msg {
				margin: 0 0 8px;
				color: var(--fg);
				font-family: var(--sans);
				font-size: 18px;
				font-weight: 500;
				letter-spacing: -0.01em;
				text-wrap: balance;
			}
			.sub {
				margin: 0 0 32px;
				color: var(--dim);
				text-wrap: pretty;
			}
			.sub code {
				color: var(--accent);
				font-size: 12.5px;
				word-break: break-word;
			}
			.links {
				margin: 0;
				display: inline-flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 12px 20px;
			}
			a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
				padding: 4px 2px;
				transition: color 120ms ease, border-color 120ms ease;
			}
			a:hover {
				color: var(--accent-2);
				border-color: var(--accent-2);
			}
			a:focus-visible {
				color: var(--accent-2);
				border-color: var(--accent-2);
				outline: 2px solid var(--accent-2);
				outline-offset: 4px;
				border-radius: 2px;
			}
			@media (max-width: 480px) {
				main { padding: 24px 18px; }
				.status { margin-bottom: 22px; }
				.sub { margin-bottom: 28px; }
			}
			@media (prefers-reduced-motion: reduce) {
				*, *::before, *::after {
					animation-duration: 0.001ms !important;
					animation-iteration-count: 1 !important;
					transition-duration: 0.001ms !important;
				}
			}
			@media (prefers-contrast: more) {
				:root {
					--dim: #e4e4e7;
					--dimmer: #c0c0c5;
					--line: #52525b;
				}
				a {
					border-bottom-color: var(--accent);
					text-decoration: underline;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<p class="status"><span class="dot" aria-hidden="true"></span>route · not found</p>
			<p class="code">404</p>
			<p class="msg">no frame at this path.</p>
			<p class="sub">public streams live at <code>/&#123;agent_slug&#125;/&#123;yyyymmdd&#125;/</code>. if you were looking for a specific stream, check the agent slug and date; otherwise pick a route below.</p>
			<nav class="links" aria-label="Recovery">
				<a href="/">home</a>
				<a href="/docs/start-here/welcome/">docs</a>
				<a href="/docs/api-reference/">api</a>
				<a href="/docs/reference/glossary/">glossary</a>
			</nav>
		</main>
	</body>
</html>
