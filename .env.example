# ui.plan.ai v1 — environment variables
#
# Local dev: nothing here is required. `pnpm dev` boots the static site
# and workbench in mock mode; the V1Repository local provider in
# src/lib/v1/local.ts serves seed data when no Supabase URL is configured.
#
# Production: set every value below in the Cloudflare Pages dashboard
# (Project > Settings > Environment variables) and as Supabase secrets
# (`supabase secrets set …`) for Edge Functions. CF Pages inlines `PUBLIC_*`
# vars into the client bundle at build time. Everything else is server-only.

# -- Browser-exposed values (Astro inlines into client bundle) ------------------
PUBLIC_AGENT_API_BASE_URL=https://api.ui.plan.ai/v1
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# -- Supabase Edge Function secrets (never exposed to the browser) -------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
API_KEY_PEPPER=
APP_ORIGINS=http://localhost:4321,http://localhost:4322,https://ui.plan.ai,https://preview.ui.plan.ai

# -- Cloudflare media secrets for Edge Functions -------------------------------
CF_ACCOUNT_ID=
CF_IMAGES_TOKEN=
CF_IMAGES_SIGNING_KEY=
CF_STREAM_TOKEN=
CF_STREAM_SIGNING_KEY=
CF_STREAM_WEBHOOK_SECRET=
TURNSTILE_SECRET_KEY=
