# ui.plan.ai v1 — environment variables
#
# Local dev: nothing here is required. The app boots in mock-backend mode
# by default; the fixtures in src/lib/fixtures/ are the data.
#
# Production (Cloudflare Pages): set every non-PUBLIC_USE_MOCK_BACKEND var
# in the CF Pages dashboard (Project > Settings > Environment variables).
# CF Pages reads them at build time, and `PUBLIC_*` vars are also inlined
# into the client bundle.
#
# Astro convention: variables prefixed with PUBLIC_ are exposed to the
# browser bundle. Everything else is server-only.

# -- Backend mode toggle ------------------------------------------------------
# When `true`, the app reads from src/lib/fixtures/ and never hits Supabase
# or Cloudflare. When `false`, the app reaches for the (not-yet-written) live
# Supabase + Cloudflare client. Default: true.
PUBLIC_USE_MOCK_BACKEND=true

# -- Supabase ----------------------------------------------------------------
# Required when PUBLIC_USE_MOCK_BACKEND=false.
# Create the project at https://supabase.com — see SETUP.md.
SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# -- Cloudflare Images (delivery for promoted image frames) ------------------
# Required when PUBLIC_USE_MOCK_BACKEND=false.
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_IMAGES_API_TOKEN=your-images-api-token
# Public delivery prefix configured in CF Images. Pattern:
#   https://imagedelivery.net/<account-hash>
PUBLIC_CLOUDFLARE_IMAGES_URL_PREFIX=https://imagedelivery.net/your-account-hash

# -- Cloudflare Stream (large video originals + playback) --------------------
# Required when PUBLIC_USE_MOCK_BACKEND=false.
CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token
# Customer subdomain configured in CF Stream — used to build playback URLs.
PUBLIC_CLOUDFLARE_STREAM_SUBDOMAIN=customer-xxxxxxxxxx

# -- Project config ----------------------------------------------------------
# Path or URL to project-config.v1.json, which carries media limits and CF
# Images variant names. Schema:
#   /docs/specs/schemas/project-config.v1.schema.json
PROJECT_CONFIG_URL=https://config.example/project-config.v1.json
