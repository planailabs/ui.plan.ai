# Cloudflare Pages reads this file from build output.
# Conservative baseline for a fully static site.

/*
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin

# Long-lived, content-hashed assets emitted by Astro.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/docs/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind search assets — content-hashed bundle, safe to cache hard.
/docs/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons rarely change; allow long cache with revalidation.
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
