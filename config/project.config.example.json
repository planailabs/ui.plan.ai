{
  "$schema": "https://ui.plan.ai/docs/specs/schemas/project-config.v1.schema.json",
  "api": {
    "base_url": "https://api.ui.plan.ai/v1",
    "metadata_max_bytes": 65536
  },
  "media": {
    "allowed_image_mime_types": ["image/png"],
    "allowed_video_mime_types": ["video/mp4", "video/webm"],
    "multipart_max_bytes": 26214400,
    "small_video_max_bytes": 10485760,
    "video_max_duration_seconds": 600,
    "click_zones_max": 50
  },
  "storage": {
    "supabase_originals_bucket": "frame-originals"
  },
  "delivery": {
    "cloudflare_image_variants": ["thumb-256", "card-768", "frame-1920", "og-1200x630"],
    "cloudflare_stream_upload_expires_seconds": 3600
  },
  "approval_defaults": {
    "initial_visibility": "draft",
    "requires_review": true
  }
}
