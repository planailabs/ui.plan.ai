{
  "api": {
    "base_url": "https://api.ui.plan.ai/v1",
    "metadata_max_bytes": 32768
  },
  "media": {
    "allowed_image_mime_types": ["image/png"],
    "allowed_video_mime_types": ["video/mp4", "video/webm"],
    "multipart_max_bytes": 10485760,
    "small_video_max_bytes": 52428800,
    "video_max_duration_seconds": 120,
    "click_zones_max": 64
  },
  "storage": {
    "supabase_originals_bucket": "frame-originals"
  },
  "delivery": {
    "cloudflare_image_variants": ["review", "public", "thumbnail"],
    "cloudflare_stream_upload_expires_seconds": 3600
  },
  "approval_defaults": {
    "initial_visibility": "draft",
    "requires_review": true
  }
}
